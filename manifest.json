{
  "manifest_version": 3,
  "name": "Olympus - Bloqueador de Overlays",
  "version": "3.1",
  "description": "Bloquea overlays, popunders y redirecciones en olympusxyz.com y olympusbiblioteca.com",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": [
    "*://olympusxyz.com/*",
    "*://*.olympusxyz.com/*",
    "*://olympusbiblioteca.com/*",
    "*://*.olympusbiblioteca.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://olympusxyz.com/*",
        "*://*.olympusxyz.com/*",
        "*://olympusbiblioteca.com/*",
        "*://*.olympusbiblioteca.com/*"
      ],
      "js": ["blocker.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "world": "MAIN"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "block_popups",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "48": "icon.png"
  }
}
